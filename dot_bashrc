alias v=nvim
alias ll="ls -la"

export EDITOR=nvim
export USER="$(id -un)"

BLUE='\033[1;34m'
PURPLE='\033[1;35m'
NC='\033[0m'
export PS1="$BLUE\u$NC@$BLUE\h$NC $PURPLE\w\n$NC "

_edit_no_execute() {
    local tmpfile=$(mktemp)
    echo "$READLINE_LINE" > "$tmpfile"
    ${EDITOR:-vim} "$tmpfile"
    READLINE_LINE=$(cat "$tmpfile")
    READLINE_POINT=${#READLINE_LINE}
    rm -f "$tmpfile"
}

bind -m vi-command -x '"v": _edit_no_execute'

eval "$(zoxide init --cmd cd bash)"
eval "$(fzf --bash)"
